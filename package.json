    "dotenv": "^16.3.2",
    "expect": "^29.7.0",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "jest-matcher-utils": "^29.7.0",
    "nodemon": "^2.0.22",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
